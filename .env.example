# =============================================================================
# Aroha Astrology Frontend — environment variables
# =============================================================================

# Backend API base — the URL of the backend Next.js deploy (aroha-astrology/backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (client-side auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Razorpay client SDK key (publishable)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Firebase phone-auth (client web SDK config — safe to expose)
NEXT_PUBLIC_FIREBASE_AUTH_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_AUTH_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_AUTH_APP_ID=

# Web Push VAPID public key (browser subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# App URL (canonical site root — used for OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000
